# Örnek ortam değişkenleri — yalnızca yerel geliştirme / Docker demo için.
# Üretim ortamında tüm değerleri güçlü, özel değerlerle değiştirin.
# Bu dosyayı kopyalayın: cp .env.example .env  (veya Windows: copy .env.example .env)

DEBUG=True
SECRET_KEY=ornek-yalnizca-yerel-gelistirme-icin-guclu-gizli-anahtar-minimum-50-karakter
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (Docker / üretim)
POSTGRES_DB=hbys_proje_kontrol
POSTGRES_USER=hbys_user
POSTGRES_PASSWORD=OrnekLocalDocker-2026!DemoOnly
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Django ayar modülü (yerel SQLite: config.settings_local)
DJANGO_SETTINGS_MODULE=config.settings
SEED_DEMO_DATA=True

# Yapay zekâ asistanı (boş bırakılırsa deterministik demo mantığı kullanılır)
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW=300
